module encoding::ini @test;
import std::encoding::ini;
import std::collections::object;

// A realistic application config used by test_large_config below.
const String LARGE_INI = `
; ---------------------------------------------------------------
; MyApp v2 — main configuration
; Generated by installer on 2026-01-15
; ---------------------------------------------------------------

app_name    = MyApp # Comment
app_version = 2.4.1
environment = production
instance_id = a3f9c1d2-7b44-4e2a-9f1e-0c3d5e6f7a8b

[server]
host             = 0.0.0.0
port             = 8443
backlog          = 128
read_timeout_ms  = 5000
write_timeout_ms = 10000
max_connections  = 1024
tls_enabled      = true
tls_cert         = /etc/myapp/certs/server.crt
tls_key          = /etc/myapp/certs/server.key
tls_min_version  = TLSv1.2
allowed_origins  = https://app.example.com,https://admin.example.com,http://localhost:3000

[database]
driver          = postgres
host            = db-primary.internal
port            = 5432
name            = myapp_prod
user            = myapp_svc
password        = s3cr3t!P@ss#2026
pool_min        = 4
pool_max        = 32
pool_idle_ms    = 30000
connect_timeout = 10
ssl_mode        = verify-full
ssl_ca          = /etc/myapp/certs/db-ca.crt
migrations_dir  = /opt/myapp/migrations

[database.replica]
host     = db-replica.internal
port     = 5432
lag_warn = 1000
lag_crit = 5000
enabled  = true

[cache]
backend        = redis
host           = cache.internal
port           = 6379
db_index       = 0
password       =
max_retries    = 3
retry_delay_ms = 100
ttl_default    = 3600
ttl_session    = 86400
ttl_rate_limit = 60
key_prefix     = myapp:prod:
tls_enabled    = false

[auth]
provider          = oauth2
issuer_url        = https://auth.example.com/realms/myapp
client_id         = myapp-backend
client_secret     = xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
redirect_uri      = https://app.example.com/auth/callback
scopes            = openid,profile,email,roles
token_expiry_s    = 3600
refresh_expiry_s  = 604800
jwks_cache_ttl    = 300
mfa_required      = true
session_cookie    = __Host-myapp_sid
bcrypt_cost       = 12

[storage]
# Primary object store
backend          = s3
region           = us-east-1
bucket           = myapp-prod-assets
endpoint         =
access_key_id    = AKIAIOSFODNN7EXAMPLE
secret_key       = wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
path_prefix      = uploads/
presign_ttl_s    = 900
max_upload_bytes = 52428800
allowed_types    = image/jpeg,image/png,image/webp,application/pdf

[logging]
level       = info
format      = json
output      = file
# On Windows the path uses backslashes
file_path   = C:\ProgramData\MyApp\logs\app.log
max_size_mb = 100
max_backups = 7
max_age_days= 30
compress    = true
sentry_dsn  = https://abc123@o0.ingest.sentry.io/0000001
sentry_env  = production

[metrics]
enabled        = true
backend        = prometheus
listen         = 127.0.0.1:9090
path           = /metrics
push_gateway   =
push_interval  = 15
labels         = app=myapp,env=production,region=us-east-1
histogram_buckets = 0.005,0.01,0.025,0.05,0.1,0.25,0.5,1,2.5,5,10

[feature_flags]
new_dashboard   = true
beta_api        = false
dark_mode       = true
ab_test_checkout= false
rate_limit_v2   = true
max_upload_v2   =
experimental    = false
`;

fn void test_large_config()
{
    Object* obj = ini::tparse(LARGE_INI, allow_inline_comments: true)!!;
    defer obj.free();

    assert(obj.get(ini::GLOBAL)!!.get_string("app_name")!!    == "MyApp");
    assert(obj.get(ini::GLOBAL)!!.get_string("app_version")!! == "2.4.1");
    assert(obj.get(ini::GLOBAL)!!.get_string("environment")!! == "production");
    assert(obj.get(ini::GLOBAL)!!.get_string("instance_id")!! == "a3f9c1d2-7b44-4e2a-9f1e-0c3d5e6f7a8b");

    Object* server = obj.get("server")!!;
    assert(server.get_string("host")!!             == "0.0.0.0");
    assert(server.get_string("port")!!             == "8443");
    assert(server.get_string("tls_enabled")!!      == "true");
    assert(server.get_string("tls_cert")!!         == "/etc/myapp/certs/server.crt");
    assert(server.get_string("allowed_origins")!!  == "https://app.example.com,https://admin.example.com,http://localhost:3000");

    Object* db = obj.get("database")!!;
    assert(db.get_string("driver")!!   == "postgres");
    assert(db.get_string("port")!!     == "5432");
    // Password contains special chars including # — must not be treated as a comment
    assert(db.get_string("password")!! == "s3cr3t!P@ss#2026");
    assert(db.get_string("ssl_mode")!! == "verify-full");
    assert(db.get_string("pool_max")!! == "32");

    Object* replica = obj.get("database.replica")!!;
    assert(replica.get_string("host")!!     == "db-replica.internal");
    assert(replica.get_string("enabled")!!  == "true");
    assert(replica.get_string("lag_crit")!! == "5000");

    Object* cache = obj.get("cache")!!;
    assert(cache.get_string("backend")!!    == "redis");
    assert(cache.get_string("password")!!   == "");
    assert(cache.get_string("ttl_session")!! == "86400");
    assert(cache.get_string("key_prefix")!! == "myapp:prod:");

    Object* auth = obj.get("auth")!!;
    assert(auth.get_string("provider")!!         == "oauth2");
    assert(auth.get_string("issuer_url")!!        == "https://auth.example.com/realms/myapp");
    assert(auth.get_string("scopes")!!            == "openid,profile,email,roles");
    assert(auth.get_string("mfa_required")!!      == "true");
    assert(auth.get_string("bcrypt_cost")!!       == "12");

    Object* storage = obj.get("storage")!!;
    assert(storage.get_string("backend")!!          == "s3");
    assert(storage.get_string("endpoint")!!         == "");
    assert(storage.get_string("max_upload_bytes")!! == "52428800");
    assert(storage.get_string("allowed_types")!!    == "image/jpeg,image/png,image/webp,application/pdf");

    Object* logging = obj.get("logging")!!;
    assert(logging.get_string("level")!!       == "info");
    assert(logging.get_string("format")!!      == "json");
    assert(logging.get_string("file_path")!!   == `C:\ProgramData\MyApp\logs\app.log`);
    assert(logging.get_string("compress")!!    == "true");

    Object* metrics = obj.get("metrics")!!;
    assert(metrics.get_string("enabled")!!           == "true");
    assert(metrics.get_string("listen")!!            == "127.0.0.1:9090");
    assert(metrics.get_string("push_gateway")!!      == "");
    assert(metrics.get_string("histogram_buckets")!! == "0.005,0.01,0.025,0.05,0.1,0.25,0.5,1,2.5,5,10");

    Object* flags = obj.get("feature_flags")!!;
    assert(flags.get_string("new_dashboard")!!    == "true");
    assert(flags.get_string("beta_api")!!         == "false");
    assert(flags.get_string("max_upload_v2")!!    == "");
    assert(flags.get_string("experimental")!!     == "false");

    int section_count = 0;
    obj.@each_entry(; String name, Object* sec)
    {
        section_count++;
    };
    assert(section_count == 10); // GLOBAL + server + database + database.replica + cache + auth + storage + logging + metrics + feature_flags
}

fn void test_basic_parse()
{
    String src = `
[server]
host = localhost
port = 8080
`;
    Object* obj = ini::tparse(src)!!;
    defer obj.free();

    assert(obj.get("server")!!.get_string("host")!! == "localhost");
    assert(obj.get("server")!!.get_string("port")!! == "8080");
}

fn void test_global_keys()
{
    String src = `
name = myapp
version = 1.0

[db]
host = localhost
`;
    Object* obj = ini::tparse(src)!!;
    defer obj.free();

    assert(obj.get(ini::GLOBAL)!!.get_string("name")!! == "myapp");
    assert(obj.get(ini::GLOBAL)!!.get_string("version")!! == "1.0");
    assert(obj.get("db")!!.get_string("host")!! == "localhost");
}

fn void test_comments()
{
    String src = `
; semicolon comment
# hash comment
[section]
; another comment
key = value
`;
    Object* obj = ini::tparse(src)!!;
    defer obj.free();

    assert(obj.get("section")!!.get_string("key")!! == "value");
    assert(obj.has_key("section"));
    assert(!obj.has_key("other"));
}

fn void test_whitespace_trimming()
{
    String src = `
[section]
key   =   value with spaces
other=nopad
`;
    Object* obj = ini::tparse(src)!!;
    defer obj.free();

    assert(obj.get("section")!!.get_string("key")!! == "value with spaces");
    assert(obj.get("section")!!.get_string("other")!! == "nopad");
}

fn void test_empty_value()
{
    String src = `
[section]
empty =
also_empty=
`;
    Object* obj = ini::tparse(src)!!;
    defer obj.free();

    assert(obj.get("section")!!.get_string("empty")!! == "");
    assert(obj.get("section")!!.get_string("also_empty")!! == "");
}

fn void test_colon_delimiter()
{
    String src = `
[section]
key: value
`;
    Object* obj = ini::tparse(src, delimiter: ':')!!;
    defer obj.free();

    assert(obj.get("section")!!.get_string("key")!! == "value");
}

fn void test_duplicate_key_overwrite()
{
    String src = `
[section]
key = first
key = second
`;
    Object* obj = ini::tparse(src)!!;
    defer obj.free();

    assert(obj.get("section")!!.get_string("key")!! == "second");
}

fn void test_duplicate_key_error()
{
    String src = `
[section]
key = first
key = second
`;
    Object*? obj = ini::tparse(src, on_duplicate_keys: ERROR);
    assert(@catch(obj) == ini::DUPLICATE_KEY);
}

fn void test_missing_key()
{
    String src = `
[section]
key = value
`;
    Object* obj = ini::tparse(src)!!;
    defer obj.free();

    assert(!@ok(obj.get("section")!!.get_string("missing")));
    assert(!@ok(obj.get("nosection")));
}

fn void test_has_section_has_key()
{
    String src = `
[alpha]
foo = bar
`;
    Object* obj = ini::tparse(src)!!;
    defer obj.free();

    assert(obj.has_key("alpha"));
    assert(!obj.has_key("beta"));
    assert(obj.get("alpha")!!.has_key("foo"));
    assert(!obj.get("alpha")!!.has_key("baz"));
}

fn void test_multiple_sections()
{
    String src = `
[a]
x = 1

[b]
x = 2

[c]
x = 3
`;
    Object* obj = ini::tparse(src)!!;
    defer obj.free();

    assert(obj.get("a")!!.get_string("x")!! == "1");
    assert(obj.get("b")!!.get_string("x")!! == "2");
    assert(obj.get("c")!!.get_string("x")!! == "3");
}

fn void test_iteration()
{
    String src = `
[section]
a = 1
b = 2
c = 3
`;
    Object* obj = ini::tparse(src)!!;
    defer obj.free();

    int count = 0;
    obj.get("section")!!.@each_entry(; String key, Object* val)
    {
        count++;
    };
    assert(count == 3);
}

fn void test_invalid_section()
{
    String src = `
[unclosed
key = value
`;
    Object*? obj = ini::tparse(src);
    assert(@catch(obj) == ini::INVALID_SECTION);
}

fn void test_empty_section_header_is_invalid()
{
    String src = "[]\nkey = value\n";
    Object*? obj = ini::tparse(src);
    assert(@catch(obj) == ini::INVALID_SECTION);
}

fn void test_encode_respects_delimiter()
{
    String src = "[section]\nkey: value\n";
    Object* obj = ini::tparse(src, delimiter: ':')!!;
    defer obj.free();

    String encoded = ini::tencode(obj, delimiter:':');
    assert(encoded.contains("[section]"));
    assert(encoded.contains("key : value"));
}

fn void test_encode_no_pad_delimiter()
{
    String src = "[section]\nkey=value\n";
    Object* obj = ini::tparse(src)!!;
    defer obj.free();

    String encoded = ini::tencode(obj, pad_delimiter: false);
    assert(encoded.contains("key=value"));
    assert(!encoded.contains("key = value"));
}

fn void test_crlf_line_endings()
{
    String src = "[section]\r\nkey = value\r\n";
    Object* obj = ini::tparse(src)!!;
    defer obj.free();

    assert(obj.get("section")!!.get_string("key")!! == "value");
}

fn void test_build_and_encode()
{
    Object* obj = object::new_obj(tmem);
    defer obj.free();

    obj.get_or_create_obj("server").set("host", "localhost");
    obj.get_or_create_obj("server").set("port", "8080");
    obj.get_or_create_obj(ini::GLOBAL).set("name", "myapp");

    assert(obj.get("server")!!.get_string("host")!! == "localhost");
    assert(obj.get("server")!!.get_string("port")!! == "8080");
    assert(obj.get(ini::GLOBAL)!!.get_string("name")!! == "myapp");
}

fn void test_round_trip()
{
    String src = `
name = myapp
version = 1.0

[server]
host = localhost
port = 8080

[edge]
empty =
spaced = hello world
`;
    Object* m1 = ini::tparse(src)!!;
    defer m1.free();

    String encoded = ini::tencode(m1);

    Object* m2 = ini::tparse(encoded)!!;
    defer m2.free();

    assert(m2.get(ini::GLOBAL)!!.get_string("name")!!    == m1.get(ini::GLOBAL)!!.get_string("name")!!);
    assert(m2.get(ini::GLOBAL)!!.get_string("version")!! == m1.get(ini::GLOBAL)!!.get_string("version")!!);
    assert(m2.get("server")!!.get_string("host")!! == m1.get("server")!!.get_string("host")!!);
    assert(m2.get("server")!!.get_string("port")!! == m1.get("server")!!.get_string("port")!!);
    assert(m2.get("edge")!!.get_string("empty")!!   == m1.get("edge")!!.get_string("empty")!!);
    assert(m2.get("edge")!!.get_string("spaced")!!  == m1.get("edge")!!.get_string("spaced")!!);
}

fn void test_each_visits_all_sections_including_global()
{
    String src = `
name = myapp

[server]
host = localhost

[db]
port = 5432
`;
    Object* obj = ini::tparse(src)!!;
    defer obj.free();

    int total = 0;
    bool saw_global = false;
    bool saw_server = false;
    bool saw_db     = false;

    obj.@each_entry(; String section, Object* sec)
    {
        sec.@each_entry(; String key, Object* val)
        {
            total++;
            if (section == ini::GLOBAL) saw_global = true;
            if (section == "server")    saw_server = true;
            if (section == "db")        saw_db     = true;
        };
    };

    assert(total == 3);
    assert(saw_global);
    assert(saw_server);
    assert(saw_db);
}

fn void test_each_empty_global_not_visited()
{
    String src = "[section]\nkey = value\n";
    Object* obj = ini::tparse(src)!!;
    defer obj.free();

    bool saw_global_key = false;
    obj.@each_entry(; String section, Object* sec)
    {
        if (section == ini::GLOBAL)
        {
            sec.@each_entry(; String key, Object* val)
            {
                saw_global_key = true;
            };
        }
    };

    assert(!saw_global_key);
}

fn void test_allow_global_keys_false_has_no_global_section()
{
    String src = "[section]\nkey = value\n";
    Object* obj = ini::tparse(src, allow_global_keys: false)!!;
    defer obj.free();

    assert(!obj.has_key(ini::GLOBAL));
}

fn void test_inline_comments()
{
    String src = `
[section]
key = value ; inline comment
other = data # hash comment
plain = no comment
`;
    Object* obj = ini::tparse(src, allow_inline_comments: true)!!;
    defer obj.free();

    assert(obj.get("section")!!.get_string("key")!! == "value");
    assert(obj.get("section")!!.get_string("other")!! == "data");
    assert(obj.get("section")!!.get_string("plain")!! == "no comment");
}
