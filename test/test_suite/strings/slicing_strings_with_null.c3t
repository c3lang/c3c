// #target: macos-x64
module test;
fn int main()
{
	const LEN = 5;
    String foo = "1234\0";
    char[LEN] bar;
    bar[:LEN] = "1234\0"[:LEN];
    return 0;
}

/* #expect: test.ll


%"char[]" = type { ptr, i64 }

@main.LEN = internal unnamed_addr constant i32 5, align 4
@.str = private unnamed_addr constant [6 x i8] c"1234\00\00", align 1
@.str.1 = private unnamed_addr constant [6 x i8] c"1234\00\00", align 1

define i32 @main() #0 {
entry:
  %foo = alloca %"char[]", align 8
  %bar = alloca [5 x i8], align 1
  store %"char[]" { ptr @.str, i64 5 }, ptr %foo, align 8
  store i8 0, ptr %bar, align 1
  %ptradd = getelementptr inbounds i8, ptr %bar, i64 1
  store i8 0, ptr %ptradd, align 1
  %ptradd1 = getelementptr inbounds i8, ptr %bar, i64 2
  store i8 0, ptr %ptradd1, align 1
  %ptradd2 = getelementptr inbounds i8, ptr %bar, i64 3
  store i8 0, ptr %ptradd2, align 1
  %ptradd3 = getelementptr inbounds i8, ptr %bar, i64 4
  store i8 0, ptr %ptradd3, align 1
  %0 = insertvalue %"char[]" undef, ptr %bar, 0
  %1 = insertvalue %"char[]" %0, i64 5, 1
  %2 = extractvalue %"char[]" %1, 0
  call void @llvm.memmove.p0.p0.i64(ptr align 1 %2, ptr align 1 @.str.1, i64 5, i1 false)
  ret i32 0
}


