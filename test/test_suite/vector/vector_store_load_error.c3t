// #target: macos-x64
module test;
import std;

struct Player
{
    float[<3>] position;
    int entity_type_id;
    float[<3>] camera_position;
    float fov_y_degrees;
    int[] inventory;
}

fn int main()
{
	float[<3>] x;
    Player player;
    player.fov_y_degrees = 70.0f;
    player.camera_position = {};
    assert(player.fov_y_degrees == 70.0f);
    x = {};
    return 0;
}

