  call void @llvm.memset.p0.i64(ptr align 8 %player, i8 0, i64 48, i1 false)
  %ptradd = getelementptr inbounds i8, ptr %player, i64 28
  store float 7.000000e+01, ptr %ptradd, align 4
  %ptradd1 = getelementptr inbounds i8, ptr %player, i64 16
  store <3 x float> zeroinitializer, ptr %ptradd1, align 8
  %ptradd2 = getelementptr inbounds i8, ptr %player, i64 28
