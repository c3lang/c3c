// #target: macos-x64
module test;
import std::io;
fn void main()
{
    int[<4>] a = { 1, -3, 5, 7 };
    bool[<4>] b = !!a;
}

/* #expect: test.ll

entry:
  %a = alloca <4 x i32>, align 16
  %b = alloca <4 x i8>, align 4
  store <4 x i32> <i32 1, i32 -3, i32 5, i32 7>, ptr %a, align 16
  %0 = load <4 x i32>, ptr %a, align 16
  %not = icmp eq <4 x i32> %0, zeroinitializer
  %1 = sext <4 x i1> %not to <4 x i32>
  %not1 = icmp eq <4 x i32> %1, zeroinitializer
  %2 = sext <4 x i1> %not1 to <4 x i8>
  store <4 x i8> %2, ptr %b, align 4
  ret void
}
