// #target: macos-x64
module test;
enum Field { A, B, C }

struct Entry
{
	Field field;
	union
	{
		int      int_val;
		bool     bool_val;
		int[<2>] vec_val;
	}
}

union Tester
{
	int x;
	int[<3>] a;
	int[3] b;
}

fn int main()
{
	Entry a;
	int[<2>] x = a.vec_val;
	Tester[2] y;
	int[<3>] z = y[0].a;
	int[<3>] z1 = y[1].a;
	return 0;
}

/* #expect: test.ll

%Entry = type { i32, %.anon }
%.anon = type { [2 x i32] }
%Tester = type { [3 x i32] }

define i32 @main() #0 {
entry:
  %a = alloca %Entry, align 4
  %x = alloca <2 x i32>, align 8
  %y = alloca [2 x %Tester], align 16
  %z = alloca <3 x i32>, align 16
  %z1 = alloca <3 x i32>, align 16
  store i32 0, ptr %a, align 4
  %ptradd = getelementptr inbounds i8, ptr %a, i64 4
  call void @llvm.memset.p0.i64(ptr align 4 %ptradd, i8 0, i64 8, i1 false)
  %ptradd1 = getelementptr inbounds i8, ptr %a, i64 4
  %0 = load <2 x i32>, ptr %ptradd1, align 4
  store <2 x i32> %0, ptr %x, align 8
  call void @llvm.memset.p0.i64(ptr align 16 %y, i8 0, i64 24, i1 false)
  %1 = load <3 x i32>, ptr %y, align 4
  %expandvec = shufflevector <3 x i32> %1, <3 x i32> poison, <4 x i32> <i32 0, i32 1, i32 2, i32 poison>
  store <4 x i32> %expandvec, ptr %z, align 16
  %ptradd2 = getelementptr inbounds i8, ptr %y, i64 12
  %2 = load <3 x i32>, ptr %ptradd2, align 4
  %expandvec3 = shufflevector <3 x i32> %2, <3 x i32> poison, <4 x i32> <i32 0, i32 1, i32 2, i32 poison>
  store <4 x i32> %expandvec3, ptr %z1, align 16
  ret i32 0
}
