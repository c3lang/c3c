// #target: macos-x64
// #safe: yes
module test;
import std::io;

fn int main()
{
    char[10] buf;

    int* i = (int*)(&buf[1]);
    int z = *i;
    int z2 = mem::load(i, 1);
    *i = 5;
    mem::store(i, 6, 1);
    int y = *i;

    return 0;
}

