enum Foo : char
{
	ABC,
	BCD
}
typedef Abc = int;
fn void main()
{
	$assert Foo.BCD - 1 == Foo.ABC; // #error:  The subtraction
	$assert Foo.ABC + 1 == Foo.BCD; // #error: Cannot do the addition
	$assert $Typeof(Foo.BCD - 1)::typeid == Foo::typeid; // #error:  The subtraction
	$assert $Typeof(Foo.ABC + 1)::typeid == Foo::typeid; // #error: Cannot do the addition
	Foo x = Foo.BCD;
	$assert $Typeof(x - 1)::typeid == Foo::typeid; // #error:  The subtraction
	x = x - 1; // #error:  The subtraction
	$assert $Typeof(x + 1)::typeid == Foo::typeid; // #error: Cannot do the addition
}
