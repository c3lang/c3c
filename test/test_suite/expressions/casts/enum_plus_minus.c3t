module test;
import std;
enum Foo : ichar
{
	ABC,
	BCD,
	BAR,
	BAZ
}

fn void main()
{
	Foo x = 1 + Foo.ABC; // #error: Cannot do the addition 'int' + 'Foo'
	ichar i = 1;
	assert(x == BCD);
	x = i + Foo.ABC; // #error: Cannot do the addition
	assert(x == BCD);
	x++;
	assert(x == BAR);
	x = -1 + x;  // #error: Cannot do the addition
	assert(x == BCD);
	x = -i + x;  // #error: Cannot do the addition
	assert(x == ABC);
	x = -1 + Foo.BAR;  // #error: Cannot do the addition
	assert(x == BCD);
}

