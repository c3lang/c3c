  %add27 = add i32 %52, 1, !dbg !280
  store i32 %add27, ptr %i, align 4, !dbg !280
  br label %loop.cond, !dbg !280

loop.exit28:                                      ; preds = %loop.cond
  call void @llvm.memcpy.p0.p0.i32(ptr align 8 %list, ptr align 8 %list5, i32 16, i1 false), !dbg !281
  %lo = load ptr, ptr %list, align 8, !dbg !282
  %ptradd29 = getelementptr inbounds i8, ptr %list, i64 8, !dbg !282
  %hi = load i64, ptr %ptradd29, align 8, !dbg !282
  %53 = call i32 @test.main(ptr %lo, i64 %hi), !dbg !283
