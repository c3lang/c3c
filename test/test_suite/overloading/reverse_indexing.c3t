// #target: linux-x64
module test;
import std;
struct Test { int v; }

fn void main()
{
	FixedList{Test, 4} t;
	t.push_all({{},{},{},{}});
	Test* tref = &t[^1];
	t[3].v = 99;
	io::printn(tref.v); // 0
	io::printn(t[3].v); // 99

	tref = &t[t.len() - 1];
	t[3].v = 88;
	io::printn(tref.v); // 88
}

