// #target: macos-aarch64
module main;
import std::io;

faultdef FAILURE;

fn int? foo(int a)
{
	if (a < 0) return FAILURE~;
	return a + 3;
}

fn int main()
{
	int x = 1;
	io::printn(foo(x)) ?? io::printn("Failure!");
	return 0;
}

