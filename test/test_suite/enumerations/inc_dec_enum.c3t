// #target: macos-x64
module test;
import std;
enum Abc
{
	ABC,
	DEF,
	GHI,
	JKL
}
fn int main()
{
	Abc foo = ABC;
	Abc a = foo++;
	Abc b = ++foo;
	Abc c = foo--;
	Abc[<1>] foo2 = { ABC };
	Abc[<1>] a2 = foo2++;
	Abc[<1>] b2 = ++foo2;
	Abc[<1>] c2 = foo2--;
    return 0;
}

