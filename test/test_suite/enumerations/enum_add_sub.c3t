// #target: macos-x64
module test;
enum Foo
{
	ABC
}
typedef Abc = inline Foo;
typedef BarInt = int;
enum Bar : BarInt
{
	ABC
}
fn int main()
{
	Foo a;
	$assert $typeof(a++).typeid == Foo.typeid;
	Abc b;
	$assert $typeof(b++).typeid == Abc.typeid;
	Bar c;
	$assert $typeof(c++).typeid == Bar.typeid;
	return 0;
}


/* #expect: test.ll

  %a = alloca i32, align 4
  %b = alloca i32, align 4
  %c = alloca i32, align 4
