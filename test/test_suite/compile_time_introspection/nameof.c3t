// #target: macos-x64
module mymodule;

extern fn void printf(char *, ...);

struct Foo { int y; }

int b;

fn void main()
{
    printf("%s\n", Foo::qname);
    printf("%s\n", $typefrom("Foo")::qname);
    printf("%s\n", Foo::name);
    printf("%s\n", $typefrom("mymodule::Foo")::name);
    printf("%s\n", Foo::cname);
    printf("%s\n", $typefrom("Foo")::cname);

    printf("%s\n", $reflect(b).qname);
    printf("%s\n", $reflect($eval("b")).qname);
    printf("%s\n", $reflect(b).name);
    printf("%s\n", $reflect($eval("mymodule::b")).name);
    printf("%s\n", $reflect(b).cname);
    printf("%s\n", $reflect($eval("b")).cname);

    int a;

    printf("%s\n", $reflect(a).qname);
    printf("%s\n", $reflect($eval("a")).qname);
    printf("%s\n", $reflect(a).name);
    printf("%s\n", $reflect($eval("a")).name);

}

