struct Foo { int a; }
struct Bar { int a; }
fn void Bar.xyz(&self) @tag("footag", 123) {}
macro void Foo.tags(&self, other)
{
    // inner to remove pointer
    var $Type = $Typeof(other)::inner;
    var $methodcount = $Type::methods.len;
    $for var $i = 0; $i < $methodcount; $i++:
        var $MethodType1 = $Typeof($Type.$eval($Type::methods[$i]));
        var $MethodType = $Typeof(&$Type.$eval($Type::methods[$i]));
		$MethodType a;
		$MethodType1 b;
        var $hasfootag = $MethodType::has_tag("footag");
    $endfor
}
fn void main() { Bar bar; Foo foo; foo.tags(&bar); }
