module test;
import std::io;

fn void main()
{
    io::printfn($stringify(asd) );
    io::printfn($stringify(asd  ) );
    io::printfn($stringify(((((asd))))));
    io::printfn($stringify( (1 + 1) ));
    io::printfn($stringify("()"));
    io::printfn($stringify(")))" ) );
}

