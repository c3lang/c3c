	bool b = MyStruct::members[0].is_anonymous;
	bool c = MyStruct::members[0].is_nested;
	bool d = MyStruct::members[1].is_anonymous;
	bool e = $Typeof(val.inner_struct)::is_anonymous;
	bool f = MyStruct::members[1].type.is_anonymous;
	bool g = $Typeof(val.inner_struct)::is_nested;
	bool h = MyStruct::members[1].is_nested;
	bool i = MyStruct::is_nested;
}
