// #target: macos-x64
// #safe: yes
module test;

<*
 @ensure return.len == size
*>
fn char[] test(char[] buf, sz size)
{
	if (size == 0) return {};
	return buf;
}


fn int main()
{
	char[128] buf;
	test(&buf, buf.len);
	return 0;
}

/* #expect: test.ll

define { ptr, i64 } @test.test(ptr %0, i64 %1, i64 %2) #0 {
entry:
  %buf = alloca %"char[]", align 8
  %taddr = alloca %"char[]", align 8
  %taddr6 = alloca %"char[]", align 8
  store ptr %0, ptr %buf, align 8
  %ptradd = getelementptr inbounds i8, ptr %buf, i64 8
  store i64 %1, ptr %ptradd, align 8
  %eq = icmp eq i64 %2, 0
  br i1 %eq, label %if.then, label %if.exit

if.then:                                          ; preds = %entry
  %eq1 = icmp eq i64 0, %2
  br i1 %eq1, label %assert_ok, label %assert_fail

assert_fail:                                      ; preds = %if.then
  %3 = load ptr, ptr @std.core.builtin.panic, align 8
  call void %3(ptr @.panic_msg, i64 38, ptr @.file, i64 20, ptr @.func, i64 4, i32 8) #2
  unreachable

assert_ok:                                        ; preds = %if.then
  store %"char[]" zeroinitializer, ptr %taddr, align 8
  %4 = load { ptr, i64 }, ptr %taddr, align 8
  ret { ptr, i64 } %4

if.exit:                                          ; preds = %entry
  %5 = load %"char[]", ptr %buf, align 8
  %ptradd2 = getelementptr inbounds i8, ptr %buf, i64 8
  %6 = load i64, ptr %ptradd2, align 8
  %eq3 = icmp eq i64 %6, %2
  br i1 %eq3, label %assert_ok5, label %assert_fail4

assert_fail4:                                     ; preds = %if.exit
  %7 = load ptr, ptr @std.core.builtin.panic, align 8
  call void %7(ptr @.panic_msg, i64 38, ptr @.file, i64 20, ptr @.func, i64 4, i32 9) #2
  unreachable

assert_ok5:                                       ; preds = %if.exit
  store %"char[]" %5, ptr %taddr6, align 8
  %8 = load { ptr, i64 }, ptr %taddr6, align 8
  ret { ptr, i64 } %8
}

define i32 @main() #0 {
entry:
  %buf = alloca [128 x i8], align 16
  %result = alloca %"char[]", align 8
  call void @llvm.memset.p0.i64(ptr align 16 %buf, i8 0, i64 128, i1 false)
  %0 = insertvalue %"char[]" undef, ptr %buf, 0
  %1 = insertvalue %"char[]" %0, i64 128, 1
  %2 = call { ptr, i64 } @test.test(ptr %buf, i64 128, i64 128)
  store { ptr, i64 } %2, ptr %result, align 8
  ret i32 0
}

