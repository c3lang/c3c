// #target: macos-x64
module foo;

module foo;

bitstruct BitField3 : char[4] @bigendian
{
    uint c : 4..19;
}

bitstruct BitField4 : char[4]
{
    uint c : 4..19;
}

extern fn void printf(char*, ...);

fn void main()
{
    test3();
}
fn void test3()
{
    //BitField3 xx = { 0xdeadbeef };
    BitField3 xx = { 0xbeaf };
    printf("%x = beaf\n", xx.c);
    BitField4 xy = { 0xbeaf };
    void *abc = &xy;
    char[4]* z = abc;
    printf("%x = beaf\n", xy.c);
    xy.c = 0xbeef;
    printf("%x = beef\n", xy.c);
    xx.c = 0xbeef;
    printf("%x = beef\n", xx.c);
}


