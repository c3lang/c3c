// #target: macos-x64
module test;
import std;

bitstruct Foo : uint
{
   uint a : 0..1;
   bool b : 6;
   bool c : 10;
   int d : 14..20;
}

fn void dummy(sz x)
{
}
fn void main()
{
	$foreach $member : Foo::members:
	{
		dummy($member.bitoffset);
		dummy($member.bitsize);
	}
	$endforeach
}


