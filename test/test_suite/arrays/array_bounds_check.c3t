// #target: macos-x64
// #safe: yes
module testing;
import std::io;

const FOO = (Foo[2]){ {11}, {22} };

struct Foo
{
	int x;
}

fn void main()
{
	for (usz i = 0; i < 20; i++)
	{
		int x = FOO[i].x;
	}
}

