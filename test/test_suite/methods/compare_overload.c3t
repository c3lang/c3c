// #target: macos-x64
module test;
struct Foo
{
	int a;
}

fn bool Foo.eq(self, Foo f) @operator(==) => self.a == f.a;

fn bool Foo.less(self, Foo f) @operator(<)
{
	return self.a < f.a;
}

fn bool Foo.less_i(self, int i) @operator(<)
{
	return self.a < i;
}

fn bool Foo.less_ir(self, int i) @operator_r(<)
{
	return i < self.a;
}

$assert Foo::is_ordered;
fn void main()
{
	Foo a = { 1 };
	Foo b = { 2 };
	bool res = a < b;
	res = a > b;
	res = a < a;
	res = a > a;
	res = a <= b;
	res = a >= b;
	res = a <= a;
	res = a >= a;
	res = a < 2;
	res = a > 2;
	res = a < 1;
	res = a > 1;
	res = a <= 2;
	res = a >= 2;
	res = a <= 1;
	res = a >= 1;
}

/* #expect: test.ll

entry:
  %a = alloca %Foo, align 4
  %b = alloca %Foo, align 4
  %res = alloca i8, align 1
  %.anon = alloca %Foo, align 4
  %.anon1 = alloca %Foo, align 4
  %.anon2 = alloca %Foo, align 4
  %.anon4 = alloca %Foo, align 4
  call void @llvm.memcpy.p0.p0.i32(ptr align 4 %a, ptr align 4 @.__const, i32 4, i1 false)
  call void @llvm.memcpy.p0.p0.i32(ptr align 4 %b, ptr align 4 @.__const.1, i32 4, i1 false)
  %0 = load i32, ptr %a, align 4
  %1 = load i32, ptr %b, align 4
  %2 = call i8 @test.Foo.less(i32 %0, i32 %1)
  store i8 %2, ptr %res, align 1
  call void @llvm.memcpy.p0.p0.i32(ptr align 4 %.anon, ptr align 4 %a, i32 4, i1 false)
  %3 = load i32, ptr %b, align 4
  %4 = load i32, ptr %.anon, align 4
  %5 = call i8 @test.Foo.less(i32 %3, i32 %4)
  store i8 %5, ptr %res, align 1
  %6 = load i32, ptr %a, align 4
  %7 = load i32, ptr %a, align 4
  %8 = call i8 @test.Foo.less(i32 %6, i32 %7)
  store i8 %8, ptr %res, align 1
  call void @llvm.memcpy.p0.p0.i32(ptr align 4 %.anon1, ptr align 4 %a, i32 4, i1 false)
  %9 = load i32, ptr %a, align 4
  %10 = load i32, ptr %.anon1, align 4
  %11 = call i8 @test.Foo.less(i32 %9, i32 %10)
  store i8 %11, ptr %res, align 1
  call void @llvm.memcpy.p0.p0.i32(ptr align 4 %.anon2, ptr align 4 %a, i32 4, i1 false)
  %12 = load i32, ptr %b, align 4
  %13 = load i32, ptr %.anon2, align 4
  %14 = call i8 @test.Foo.less(i32 %12, i32 %13)
  %15 = trunc i8 %14 to i1
  %not = xor i1 %15, true
  %16 = zext i1 %not to i8
  store i8 %16, ptr %res, align 1
