  %not6 = xor i1 %30, true
  %31 = zext i1 %not6 to i8
  store i8 %31, ptr %res, align 1
  %32 = load i32, ptr %a, align 4
  %33 = call i8 @test.Foo.less_i(i32 %32, i32 2)
  store i8 %33, ptr %res, align 1
  %34 = load i32, ptr %a, align 4
  %35 = call i8 @test.Foo.less_ir(i32 %34, i32 2)
  store i8 %35, ptr %res, align 1
  %36 = load i32, ptr %a, align 4
  %37 = call i8 @test.Foo.less_i(i32 %36, i32 1)
  store i8 %37, ptr %res, align 1
