// #target: macos-x64
// #debuginfo: yes
module test;
import std::io;

struct Ghh
{
	int a;
	int b;
	int c;
}
fn void main()
{
	int a = 111;
	int x = @atomic_load(a);
	int y = @atomic_load(a, RELAXED, true);
	@atomic_store(a, 123 + x);
	@atomic_store(a, 33 + y, RELAXED, true);
	io::printfn("%d", a);
}

/* #expect: test.ll
