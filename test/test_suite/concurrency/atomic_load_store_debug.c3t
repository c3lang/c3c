    #dbg_declare(ptr %y, !24, !DIExpression(), !25)
  %1 = load atomic volatile i32, ptr %a monotonic, align 4, !dbg !26
  store i32 %1, ptr %y, align 4, !dbg !26
  %2 = load i32, ptr %x, align 4, !dbg !29
