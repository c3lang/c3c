// #target: macos-x64
module test;
import std::io;
import std::collections::orderedmap;

alias IntStringMap     = OrderedMap{int, String};
alias IntStringMapDesc = OrderedMapDesc{int, String};
alias FloatIntMap      = OrderedMap{float, int};
alias LongBoolMap      = OrderedMap{long, bool};
alias CharDoubleMap    = OrderedMap{char, double};

fn void test_basic_insert_and_get()
{
    IntStringMap m;
    m.tinit();
    defer m.free();

    m.set(2, "banana");
    m.set(1, "apple");
    m.set(3, "cherry");

    io::printfn("get 1: %s", m.get(1)!!);
    io::printfn("get 2: %s", m.get(2)!!);
    io::printfn("get 3: %s", m.get(3)!!);
    if (try m.get(99))
    {
        io::printfn("get 99: found (unexpected)");
    }
    else
    {
        io::printfn("get 99: not found");
    }
}

fn void test_update()
{
    IntStringMap m;
    m.tinit();
    defer m.free();

    m.set(1, "one");
    m.set(1, "ONE");
    io::printfn("updated key: %s", m.get(1)!!);
    io::printfn("len after update: %s", m.len());
}

fn void test_has_and_len()
{
    IntStringMap m;
    m.tinit();
    defer m.free();

    io::printfn("empty: %s", m.is_empty());
    m.set(1, "a");
    m.set(2, "b");
    io::printfn("len: %s", m.len());
    io::printfn("has 1: %s", m.has_key(1));
    io::printfn("has 9: %s", m.has_key(9));
    io::printfn("empty: %s", m.is_empty());
}

fn void test_remove()
{
    IntStringMap m;
    m.tinit();
    defer m.free();

    m.set(1, "one");
    m.set(2, "two");
    io::printfn("remove 1: %s", m.remove(1));
    io::printfn("remove 1 again: %s", m.remove(1));
    io::printfn("len after remove: %s", m.len());
    io::printfn("has 1: %s", m.has_key(1));
    io::printfn("get 2: %s", m.get(2)!!);
}

fn void test_clear()
{
    IntStringMap m;
    m.tinit();
    defer m.free();

    m.set(1, "one");
    m.set(2, "two");
    m.clear();
    io::printfn("len after clear: %s", m.len());
    io::printfn("empty after clear: %s", m.is_empty());
    m.set(3, "three");
    io::printfn("len after re-insert: %s", m.len());
}

fn void test_sorted_iteration()
{
    IntStringMap m;
    m.tinit();
    defer m.free();

    m.set(50, "fifty");
    m.set(10, "ten");
    m.set(30, "thirty");
    m.set(20, "twenty");

    // Keys must come out in ascending sorted order
    io::print("sorted: ");
    foreach (entry : m.iter())
    {
        io::printf("%d=%s ", entry.key, entry.value);
    }
    io::printn();
}

fn void test_first_last()
{
    IntStringMap m;
    m.tinit();
    defer m.free();

    m.set(30, "thirty");
    m.set(10, "ten");
    m.set(20, "twenty");

    io::printfn("first key: %d", m.first_key()!!);
    io::printfn("last key:  %d", m.last_key()!!);
}

fn void test_float_keys()
{
    FloatIntMap m;
    m.tinit();
    defer m.free();

    m.set(3.14f, 1);
    m.set(1.0f, 2);
    m.set(2.71f, 3);

    io::print("float sorted: ");
    foreach (entry : m.iter())
    {
        io::printf("%.2f=%d ", entry.key, entry.value);
    }
    io::printn();
}

fn void test_long_bool_keys()
{
    LongBoolMap m;
    m.tinit();
    defer m.free();

    m.set(1000L, true);
    m.set(500L, false);
    m.set(2000L, true);

    io::print("long sorted: ");
    foreach (entry : m.iter())
    {
        io::printf("%d=%s ", entry.key, entry.value);
    }
    io::printn();
}

fn void test_descending()
{
    IntStringMapDesc m;
    m.tinit();
    defer m.free();

    m.set(10, "ten");
    m.set(50, "fifty");
    m.set(30, "thirty");
    m.set(20, "twenty");

    // Keys must come out in descending order
    io::print("descending: ");
    foreach (entry : m.iter())
    {
        io::printf("%d=%s ", entry.key, entry.value);
    }
    io::printn();

    io::printfn("first key: %d", m.first_key()!!);
    io::printfn("last key:  %d", m.last_key()!!);
}

fn void test_char_double_keys()
{
    CharDoubleMap m;
    m.tinit();
    defer m.free();

    m.set('z', 26.0);
    m.set('a', 1.0);
    m.set('m', 13.0);

    io::print("char sorted: ");
    foreach (entry : m.iter())
    {
        io::printf("%c=%.0f ", entry.key, entry.value);
    }
    io::printn();
}

fn void test_floor_ceiling()
{
    IntStringMap m;
    m.tinit();
    defer m.free();

    m.set(10, "ten");
    m.set(20, "twenty");
    m.set(30, "thirty");
    m.set(40, "forty");

    // floor: greatest key <= target
    io::printfn("floor(25): %d", m.floor_key(25)!!);   // 20
    io::printfn("floor(20): %d", m.floor_key(20)!!);   // 20 (exact)
    io::printfn("floor(10): %d", m.floor_key(10)!!);   // 10 (exact)
    if (try m.floor_key(5)) { io::printfn("floor(5): found"); } else { io::printfn("floor(5): not found"); }

    // ceiling: least key >= target
    io::printfn("ceil(25): %d", m.ceiling_key(25)!!);  // 30
    io::printfn("ceil(20): %d", m.ceiling_key(20)!!);  // 20 (exact)
    if (try m.ceiling_key(45)) { io::printfn("ceil(45): found"); } else { io::printfn("ceil(45): not found"); }

    // lower: greatest key strictly < target
    io::printfn("lower(25): %d", m.lower_key(25)!!);   // 20
    io::printfn("lower(20): %d", m.lower_key(20)!!);   // 10
    if (try m.lower_key(10)) { io::printfn("lower(10): found"); } else { io::printfn("lower(10): not found"); }

    // higher: least key strictly > target
    io::printfn("higher(25): %d", m.higher_key(25)!!); // 30
    io::printfn("higher(30): %d", m.higher_key(30)!!); // 40
    if (try m.higher_key(40)) { io::printfn("higher(40): found"); } else { io::printfn("higher(40): not found"); }
}

fn void test_pop()
{
    IntStringMap m;
    m.tinit();
    defer m.free();

    m.set(10, "ten");
    m.set(20, "twenty");
    m.set(30, "thirty");

    Entry{int, String} first = m.pop_first()!!;
    io::printfn("pop_first: %d=%s", first.key, first.value);
    io::printfn("len after pop_first: %s", m.len());

    Entry{int, String} last = m.pop_last()!!;
    io::printfn("pop_last: %d=%s", last.key, last.value);
    io::printfn("len after pop_last: %s", m.len());
}

fn void test_get_ref()
{
    IntStringMap m;
    m.tinit();
    defer m.free();

    m.set(1, "hello");
    String* ref = m.get_ref(1);
    io::printfn("get_ref: %s", *ref);
    *ref = "world";
    io::printfn("after mutation: %s", m.get(1)!!);

    String* missing = m.get_ref(99);
    io::printfn("get_ref missing: %s", missing == null);
}

fn void test_get_or_set()
{
    IntStringMap m;
    m.tinit();
    defer m.free();

    String v1 = m.get_or_set(1, "default");
    io::printfn("get_or_set new: %s", v1);
    io::printfn("len after get_or_set: %s", m.len());

    m.set(2, "existing");
    String v2 = m.get_or_set(2, "default");
    io::printfn("get_or_set existing: %s", v2);
}

fn void test_clone()
{
    IntStringMap m;
    m.tinit();
    defer m.free();

    m.set(1, "one");
    m.set(2, "two");
    m.set(3, "three");

    var c @safeinfer = m.tclone();
    defer c.free();

    // Modify original, clone should be unaffected
    m.set(1, "ONE");
    io::printfn("original 1: %s", m.get(1)!!);
    io::printfn("clone 1: %s", c.get(1)!!);
    io::printfn("clone len: %s", c.len());
}

fn void test_merge()
{
    IntStringMap a;
    a.tinit();
    defer a.free();

    IntStringMap b;
    b.tinit();
    defer b.free();

    a.set(1, "one");
    a.set(2, "two");
    b.set(2, "TWO");
    b.set(3, "three");

    a.merge(&b);

    io::printfn("merged 1: %s", a.get(1)!!);
    io::printfn("merged 2: %s", a.get(2)!!); // TWO (b overwrites)
    io::printfn("merged 3: %s", a.get(3)!!);
    io::printfn("merged len: %s", a.len());
}

fn void test_iter_from()
{
    IntStringMap m;
    m.tinit();
    defer m.free();

    m.set(10, "ten");
    m.set(20, "twenty");
    m.set(30, "thirty");
    m.set(40, "forty");

    io::print("iter_from(20): ");
    foreach (entry : m.iter_from(20))
    {
        io::printf("%d=%s ", entry.key, entry.value);
    }
    io::printn();

    io::print("iter_from(25): ");
    foreach (entry : m.iter_from(25))
    {
        io::printf("%d=%s ", entry.key, entry.value);
    }
    io::printn();
}

fn void test_iter_range()
{
    IntStringMap m;
    m.tinit();
    defer m.free();

    m.set(10, "ten");
    m.set(20, "twenty");
    m.set(30, "thirty");
    m.set(40, "forty");

    io::print("iter_range(15, 35): ");
    foreach (entry : m.iter_range(15, 35))
    {
        io::printf("%d=%s ", entry.key, entry.value);
    }
    io::printn();

    io::print("iter_range(10, 30): ");
    foreach (entry : m.iter_range(10, 30))
    {
        io::printf("%d=%s ", entry.key, entry.value);
    }
    io::printn();
}

fn bool int_cmp_desc(int a, int b) => a > b;

fn void test_custom_cmp()
{
    PrivateOrderedMap{int, String, false} m;
    m.tinit_with_cmp(&int_cmp_desc);
    defer m.free();

    m.set(10, "ten");
    m.set(50, "fifty");
    m.set(30, "thirty");

    // Should iterate in descending order via custom comparator
    io::print("custom desc: ");
    foreach (entry : m.iter())
    {
        io::printf("%d=%s ", entry.key, entry.value);
    }
    io::printn();
}

fn void test_operators()
{
    // Operators are defined on PrivateOrderedMap (inline typedef does not propagate @operator).
    PrivateOrderedMap{int, String, false} m;
    m.tinit();
    defer m.free();

    // [=] operator: false = new insert, true = update
    bool was_update = (m[1] = "one");
    io::printfn("insert new: %s", was_update);      // false
    was_update = (m[1] = "ONE");
    io::printfn("insert update: %s", was_update);   // true

    // [] operator: same as get, returns optional
    io::printfn("[] get: %s", m[1]!!);
    if (try m[99]) { io::printfn("[] missing: found"); } else { io::printfn("[] missing: not found"); }

    // &[] operator: same as get_ref, returns pointer
    String* ref = &m[1];
    *ref = "world";
    io::printfn("&[] mutation: %s", m[1]!!);
    String* missing = &m[99];
    io::printfn("&[] missing null: %s", missing == null);
}

fn void main()
{
    test_basic_insert_and_get();
    test_update();
    test_has_and_len();
    test_remove();
    test_clear();
    test_sorted_iteration();
    test_first_last();
    test_float_keys();
    test_long_bool_keys();
    test_descending();
    test_char_double_keys();
    test_floor_ceiling();
    test_pop();
    test_get_ref();
    test_get_or_set();
    test_clone();
    test_merge();
    test_iter_from();
    test_iter_range();
    test_custom_cmp();
    test_operators();
}

// #expect: test.ll
%"PrivateOrderedMap{int, String, false}" = type { %any, ptr, i32, i64, i64, ptr }
%"OrderedMapIterator{int, String, false}" = type { ptr, ptr, i64 }
%"Entry{int, String}" = type { i32, %"char[]" }
%"PrivateOrderedMap{float, int, false}" = type { %any, ptr, i32, i64, i64, ptr }
%"Entry{float, int}" = type { float, i32 }
%"PrivateOrderedMap{long, bool, false}" = type { %any, ptr, i32, i64, i64, ptr }
%"Entry{long, bool}" = type { i64, i8 }
%"PrivateOrderedMap{int, String, true}" = type { %any, ptr, i32, i64, i64, ptr }
%"OrderedMapIterator{int, String, true}" = type { ptr, ptr, i64 }
%"PrivateOrderedMap{char, double, false}" = type { %any, ptr, i32, i64, i64, ptr }
%"Entry{char, double}" = type { i8, double }
%"OrderedMapRangeIterator{int, String, false}" = type { ptr, ptr, ptr, i64, i64 }

// #expect: std.collections.orderedmap.ll
%"SkipNode{int, String}" = type { i32, %"char[]", i32, [32 x ptr] }
%"SkipNode{float, int}" = type { float, i32, i32, [32 x ptr] }
%"SkipNode{long, bool}" = type { i64, i8, i32, [32 x ptr] }
%"SkipNode{char, double}" = type { i8, double, i32, [32 x ptr] }
