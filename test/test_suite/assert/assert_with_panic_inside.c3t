struct TextTemplate { TextTag tags; }
struct TextTag { usz start; }
faultdef BAD;
<*
 @require tag_start != BAD~!!
 *>
fn void? TextTemplate.init(&self, String , String tag_start = "", String tag_end = "", void* using )
{
}
module text_test;
