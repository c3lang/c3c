{
  "provides": "clib3",
  "templates": {
    "native_feature": {
      "features": ["CLIB3_TEMPLATE_TEST"]
    },
    "native_local_feature": {
      "features": ["CLIB3_LOCAL_TEST"]
    }
  },
  "features": {
    "CLIB3_TEMPLATE_TEST": {
      "c-sources": ["feature.c"]
    },
    "CLIB3_LOCAL_TEST": {
      "c-sources": ["local_feature.c"]
    }
  },
  "targets": {
    "macos-x64": {},
    "macos-aarch64": {},
    "netbsd-x64": {},
    "netbsd-aarch64": {},
    "openbsd-x64": {},
    "linux-x64": {},
    "windows-x64": {},
    "android-aarch64": {},
    "android-x86_64": {}
  }
}
